{
    "name": "philiprehberger/laravel-db-expressions",
    "description": "Database-agnostic SQL expression helper for date truncation, extraction, and differences across SQLite and MySQL.",
    "keywords": ["laravel", "database", "sql", "date", "expressions", "sqlite", "mysql"],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/philiprehberger/laravel-db-expressions",
    "authors": [
        {
            "name": "Philip Rehberger",
            "email": "me@philiprehberger.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\DbExpressions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\DbExpressions\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhilipRehberger\\DbExpressions\\DbExpressionsServiceProvider"
            ],
            "aliases": {
                "DbExpressions": "PhilipRehberger\\DbExpressions\\Facades\\DbExpressions"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
